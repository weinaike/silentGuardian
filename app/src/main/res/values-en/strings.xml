    <!-- Permission dialog messages (HTML) -->
    <string name="perm_guide_notification_msg"><![CDATA[You will be redirected to the Notification settings.<br><br>To keep the anti-addiction service running stably in the background, we need to display a persistent notification. Please enable <font color=\'#4CAF50\'><b>Allow Notifications</b></font> in the next screen.]]></string>
    <string name="perm_guide_usage_msg"><![CDATA[You will be redirected to the Usage Access settings.<br><br>To accurately detect when you are using guarded apps, please find <b>AI Voice Lock</b> in the list and enable <font color=\'#4CAF50\'><b>[Allow usage access]</b></font>.]]></string>
    <string name="perm_guide_battery_msg"><![CDATA[You will be redirected to the Battery Optimization settings.<br><br>Android\'s battery-saving mechanism may forcibly close background apps. To ensure the guardian service works properly, please set it to <font color=\'#4CAF50\'><b>[Unrestricted]</b></font> or <font color=\'#4CAF50\'><b>[Not optimized]</b></font>.]]></string>
    <string name="perm_guide_vpn_msg"><![CDATA[A system-level Network Connection Request dialog will appear.<br><br>This feature only creates a local virtual black hole to block network access for guarded apps. It will never upload any of your traffic data. Please confidently tap <font color=\'#4CAF50\'><b>[OK]</b></font>.]]></string>

