<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_surface"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="关于"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp"
        android:layout_gravity="center_horizontal"/>

    <!-- 查看用户协议与隐私政策 -->
    <LinearLayout
        android:id="@+id/llViewPrivacy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="查看用户协议与隐私政策"
            android:textSize="16sp"
            android:textColor="@color/text_primary"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginHorizontal="16dp"/>

    <!-- 撤回同意 -->
    <LinearLayout
        android:id="@+id/llWithdrawPrivacy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="撤回隐私协议授权"
            android:textSize="16sp"
            android:textColor="#F44336"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="撤回后将清空所有数据并退出应用"
            android:textSize="13sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginHorizontal="16dp"/>

    <!-- 检查更新 -->
    <LinearLayout
        android:id="@+id/llCheckUpdate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground">
        <TextView
            android:id="@+id/tvAboutVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="检查更新"
            android:textSize="16sp"
            android:textColor="@color/text_primary"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="检查云端是否有新版本可用"
            android:textSize="13sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginHorizontal="16dp"/>

    <!-- 公司信息与备案号 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tvCompanyName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="杭州市钱塘区越思软件开发工作室"
            android:textSize="12sp"
            android:textColor="@color/text_hint"/>

        <TextView
            android:id="@+id/tvIcpNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="浙ICP备XXXXXXXX号"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tvGonganNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="浙公网安备XXXXXX号"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="8dp"/>
    </LinearLayout>

</LinearLayout>

