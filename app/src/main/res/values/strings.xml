    <!-- Permission dialog messages (HTML) -->
    <string name="perm_guide_notification_msg"><![CDATA[接下来将跳转至「通知」设置。<br><br>为了保证防沉迷服务在后台持续稳定运行而不被清理，我们需要常驻一条系统通知。请在接下来的界面中打开<font color=\'#4CAF50\'><b>允许通知</b></font>的开关。]]></string>
    <string name="perm_guide_usage_msg"><![CDATA[接下来将跳转至「使用情况访问权限」设置。<br><br>为了能够准确判断您当前是否正在使用受管 App，请在接下来的列表中找到「AI 语音锁」，并将其状态修改为<font color=\'#4CAF50\'><b>【允许访问使用记录】</b></font>。]]></string>
    <string name="perm_guide_battery_msg"><![CDATA[接下来将跳转至「电池优化」设置。<br><br>由于 Android 系统的省电机制会强制关闭后台应用，为了防沉迷服务能稳定生效，请务必将其设置为<font color=\'#4CAF50\'><b>【无限制】</b></font>或<font color=\'#4CAF50\'><b>【不优化】</b></font>。]]></string>
    <string name="perm_guide_vpn_msg"><![CDATA[接下来将弹出系统级别的「网络连接请求」确认框。<br><br>此功能仅用于在设备本地建立虚拟黑洞来阻断受管 App 的网络，绝对不会上传您的任何流量数据。请放心点击<font color=\'#4CAF50\'><b>【确定】</b></font>。]]></string>

