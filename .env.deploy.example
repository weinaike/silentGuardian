# SilentGuardian 部署凭证模板
#
# 用法：
#   1. cp .env.deploy.example .env.deploy
#   2. 填入真实值（.env.deploy 已被 .gitignore 排除）
#   3. 直接 bash deploy.sh 即可，脚本会自动 source .env.deploy
#
# 或者在 ~/.zshrc 中 export 后重开终端。

# SSH 目标主机。需要预先配置好 SSH 公钥免密登录。
# 格式：user@host 或 user@ip
SG_DEPLOY_HOST=admin@your.server.com

# 服务器上 APK 与 update_config.json 存放目录的绝对路径。
# 该目录必须对 SG_DEPLOY_HOST 用户可写，且最终通过 DOWNLOAD_BASE_URL
# (https://www.yes-tek.com/assets/apk) 能对外访问。
SG_DEPLOY_PATH=/home/admin/website/assets/apk
